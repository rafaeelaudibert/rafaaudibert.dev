#!/bin/sh
# Pre-commit hook: validates all travel images before each commit.
#
# Checks:
#   1. EXIF metadata — only date (+ optional description) allowed
#   2. ImageDescription — every image needs a valid caption
#
# Activated via `bun install` → postinstall sets core.hooksPath to .githooks
#
# If blocked:
#   bun run strip-metadata --auto   # fix metadata
#   bun run describe-images         # add missing descriptions

echo "Checking travel image metadata..."
bun run check-metadata || exit 1

echo "Checking travel image descriptions..."
bun run check-descriptions || exit 1
