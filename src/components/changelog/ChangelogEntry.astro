---
import { resolveChangelogEntry } from "../../data/changelogPhotos"

interface Props {
  year?: number | undefined
  month: string
  wip?: boolean
  entryId?: string
}

const { year, month, wip = false } = Astro.props
const { entryId: resolvedEntryId, photos } = resolveChangelogEntry(month, year)
const entryId = Astro.props.entryId ?? resolvedEntryId
---

<section class:list={[{ "has-year": year }]}>
  {year && <h2 class="section-year">{year}</h2>}

  <div class="month-column">
    <h3 class="section-month">{month}{wip ? <>&nbsp;&nbsp;&nbsp;🚧</> : ""}</h3>

    {
      photos.length > 0 && (
        <div class="entry-photos">
          {photos.map((photo, index) => (
            <button
              type="button"
              class="photo-thumb"
              data-gallery-open={entryId}
              data-image-index={index}
              aria-label={`View photo: ${photo.alt}`}
            >
              <img
                src={photo.placeholderSrc}
                alt=""
                aria-hidden="true"
                class="photo-thumb-image"
                width={48}
                height={48}
                decoding="async"
                loading="eager"
              />
            </button>
          ))}
        </div>
      )
    }
  </div>

  <div class:list={["content", { "wip-content": wip }]}>
    {
      wip && (
        <div class="construction-banner" title="Still in progress">
          🚧
        </div>
      )
    }

    <slot />
  </div>
</section>

<style>
  section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--gray-200);

    &:has(.section-year) {
      margin-top: 3rem;
    }
  }

  .section-year {
    grid-column-start: 1;
    font-size: var(--text-xl);
    color: var(--gray-0);
  }

  .month-column {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.35rem;
  }

  .section-month {
    font-size: var(--text-lg);
    color: var(--gray-0);
    line-height: 1.2;
  }

  .entry-photos {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.25rem;
    max-width: 9.5rem;
  }

  .photo-thumb {
    display: block;
    padding: 0;
    border: 1px solid var(--gray-500);
    border-radius: 0.25rem;
    background: var(--gray-600);
    cursor: pointer;
    overflow: hidden;
    line-height: 0;
    transition: border-color var(--theme-transition);
  }

  .photo-thumb:hover {
    border-color: var(--accent-regular);
  }

  .photo-thumb:focus-visible {
    outline: 2px solid var(--accent-regular);
    outline-offset: 2px;
  }

  .photo-thumb-image {
    display: block;
    width: 1.75rem;
    height: 1.75rem;
    max-width: none;
    object-fit: cover;
  }

  .content {
    grid-column: 3 / 5;

    p:not(:last-child) {
      margin-bottom: 1rem;
    }

    a {
      text-decoration: 1px solid underline transparent;
      text-underline-offset: 0.25em;
      transition: text-decoration-color var(--theme-transition);

      &:hover,
      &:focus {
        text-decoration-color: currentColor;
      }
    }
  }

  .wip-content {
    position: relative;
    border: 2px dashed #fbbf24;
    border-radius: 0.75rem;
    padding: 1rem;
    background: rgba(251, 191, 36, 0.05);
  }

  .construction-banner {
    position: absolute;
    top: -0.5rem;
    right: 1rem;
    background: #fbbf24;
    color: #92400e;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    font-weight: bold;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%,
    20%,
    50%,
    80%,
    100% {
      transform: translateY(0);
    }
    40% {
      transform: translateY(-3px);
    }
    60% {
      transform: translateY(-1px);
    }
  }

  @media (min-width: 50em) {
    section {
      display: contents;
      font-size: var(--text-lg);

      &:has(.section-year) {
        margin-top: 0;
      }
    }

    .month-column {
      grid-column-start: 2;
      align-self: start;
    }

    .has-year .section-year,
    .has-year .month-column,
    .has-year .content {
      margin-top: 3rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .photo-thumb {
      transition: border-color var(--theme-transition);
    }

    .photo-thumb:hover {
      transform: none;
    }

    .construction-banner {
      animation: none;
    }
  }
</style>
